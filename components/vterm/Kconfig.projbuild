menu "vterm"

    config VTERM_BUF_SIZE
        int "Write buffer size (bytes)"
        default 256
        help
            Internal accumulation buffer for vterm_write().

    config VTERM_BENCH
        bool "Enable performance instrumentation"
        default n
        help
            Accumulates cycle counts and byte statistics across flush calls.
            Call vterm_bench_report() to log a summary.
            Zero overhead when disabled.

endmenu
